<body>
    <h3>Create a New Listing</h3>
    <form action="/listings" method="POST">
    <input  type="text" name="listing[title]" placeholder="enter title">
    <br> <br>
    <textarea  type="text" name="listing[description]" placeholder="enter description ">
    <br><br>
    <input type="text"  name="listing[image]" placeholder="enter img URL/link">
    <br><br>
    <input type="number" name="listing[price]" placeholder="enter price">
    <br><br>
     <input type="text"  name="listing[country]" placeholder="enter your country">
    <br><br>
    <input type="text"  name="listing[loction]" placeholder="enter location">
    <br><br>
    <button>Add it! </button>
    </form>

</body>
